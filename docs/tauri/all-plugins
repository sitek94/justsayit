 81 | import { load } from '@tauri-apps/plugin-store';
 82 | // when using `"withGlobalTauri": true`, you may use
 83 | // const { load } = window.__TAURI__.store;
 84 | 
 85 | // Create a new store or load the existing one,
 86 | // note that the options will be ignored if a `Store` with that path has already been created
 87 | const store = await load('store.json', { autoSave: false });
 88 | 
 89 | // Set a value.
 90 | await store.set('some-key', { value: 5 });
 91 | 
 92 | // Get a value.
 93 | const val = await store.get<{ value: number }>('some-key');
 94 | console.log(val); // { value: 5 }
 95 | 
 96 | // You can manually save the store after making changes.
 97 | // Otherwise, it will save upon graceful exit
 98 | // And if you set `autoSave` to a number or left empty,
 99 | // it will save the changes to disk after a debounce delay, 100ms by default.
100 | await store.save();
