 61 |                       #[cfg(mobile)]
 62 |                       app.handle().plugin(tauri_plugin_nfc::init());
 63 |                       Ok(())
 64 |                   })
 65 |                   .run(tauri::generate_context!())
 66 |                   .expect("error while running tauri application");
 67 |           }
 68 |           ```
 69 | 
 70 |       3.  Install the JavaScript Guest bindings using your preferred JavaScript package manager:
 71 | 
 72 |           <CommandTabs
 73 |               npm="npm install @tauri-apps/plugin-nfc"
 74 |               yarn="yarn add @tauri-apps/plugin-nfc"
 75 |               pnpm="pnpm add @tauri-apps/plugin-nfc"
