122 |             // Note that values must be serde_json::Value instances,
123 |             // otherwise, they will not be compatible with the JavaScript bindings.
124 |             store.set("some-key", json!({ "value": 5 }));
125 | 
126 |             // Get a value from the store.
127 |             let value = store.get("some-key").expect("Failed to get value from store");
128 |             println!("{}", value); // {"value":5}
129 | 
130 |             // Remove the store from the resource table
