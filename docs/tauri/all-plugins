 64 |                       app.handle().plugin(tauri_plugin_barcode_scanner::init());
 65 |                       Ok(())
 66 |                   })
 67 |                   .run(tauri::generate_context!())
 68 |                   .expect("error while running tauri application");
 69 |           }
 70 |           ```
