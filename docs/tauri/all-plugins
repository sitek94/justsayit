 83 | ## Usage
 84 | 
 85 | The autostart plugin is available in both JavaScript and Rust.
 86 | 
 87 | <Tabs syncKey="lang">
 88 |   <TabItem label="JavaScript">
 89 | 
 90 | ```javascript
 91 | import { enable, isEnabled, disable } from '@tauri-apps/plugin-autostart';
 92 | // when using `"withGlobalTauri": true`, you may use
 93 | // const { enable, isEnabled, disable } = window.__TAURI__.autostart;
 94 | 
 95 | // Enable autostart
 96 | await enable();
 97 | // Check enable state
 98 | console.log(`registered for autostart? ${await isEnabled()}`);
 99 | // Disable autostart
100 | disable();
101 | ```
102 | 
103 |   </TabItem>
104 |   <TabItem label="Rust">
105 | 
106 | ```rust
107 | #[cfg_attr(mobile, tauri::mobile_entry_point)]
108 | pub fn run() {
109 |     tauri::Builder::default()
110 |         .setup(|app| {
111 |             #[cfg(desktop)]
112 |             {
113 |                 use tauri_plugin_autostart::MacosLauncher;
114 |                 use tauri_plugin_autostart::ManagerExt;
115 | 
116 |                 app.handle().plugin(tauri_plugin_autostart::init(
117 |                     MacosLauncher::LaunchAgent,
118 |                     Some(vec!["--flag1", "--flag2"]),
119 |                 ));
120 | 
121 |                 // Get the autostart manager
122 |                 let autostart_manager = app.autolaunch();
123 |                 // Enable autostart
124 |                 let _ = autostart_manager.enable();
125 |                 // Check enable state
126 |                 println!("registered for autostart? {}", autostart_manager.is_enabled().unwrap());
127 |                 // Disable autostart
128 |                 let _ = autostart_manager.disable();
129 |             }
130 |             Ok(())
131 |         })
132 |         .run(tauri::generate_context!())
133 |         .expect("error while running tauri application");
134 | }
135 | ```
136 | 
137 |   </TabItem>
138 | </Tabs>
