 39 |       yarn="yarn run tauri add barcode-scanner"
 40 |       pnpm="pnpm tauri add barcode-scanner"
 41 |       deno="deno task tauri add barcode-scanner"
 42 |       bun="bun tauri add barcode-scanner"
