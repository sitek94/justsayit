 56 |             pub fn run() {
 57 |                 tauri::Builder::default()
 58 |                     .setup(|app| {
 59 |                         #[cfg(desktop)]
 60 |                         app.handle().plugin(tauri_plugin_autostart::init(tauri_plugin_autostart::MacosLauncher::LaunchAgent, Some(vec!["--flag1", "--flag2"]) /* arbitrary number of args to pass to your app */));
 61 |                         Ok(())
 62 |                     })
 63 |                     .run(tauri::generate_context!())
 64 |                     .expect("error while running tauri application");
 65 |             }
 66 |             ```
 67 | 
 68 |         3.  You can install the JavaScript Guest bindings using your preferred JavaScript package manager:
 69 | 
 70 |             <CommandTabs
 71 |                 npm="npm install @tauri-apps/plugin-autostart"
 72 |                 yarn="yarn add @tauri-apps/plugin-autostart"
 73 |                 pnpm="pnpm add @tauri-apps/plugin-autostart"
 74 |                 deno="deno add npm:@tauri-apps/plugin-autostart"
 75 |                 bun="bun add @tauri-apps/plugin-autostart"
 76 |             />
 77 | 
 78 |       </Steps>
 79 |     </TabItem>
 80 | 
 81 | </Tabs>
