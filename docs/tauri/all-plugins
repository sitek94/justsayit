 54 |             #[cfg_attr(mobile, tauri::mobile_entry_point)]
 55 |             pub fn run() {
 56 |                 tauri::Builder::default()
 57 |                     .setup(|app| {
 58 |                         #[cfg(mobile)]
 59 |                         app.handle().plugin(tauri_plugin_biometric::Builder::new().build());
 60 |                         Ok(())
 61 |                     })
 62 |                     .run(tauri::generate_context!())
 63 |                     .expect("error while running tauri application");
 64 |             }
 65 |             ```
 66 | 
 67 |         3.  Install the JavaScript Guest bindings using your preferred JavaScript package manager:
 68 | 
 69 |             <CommandTabs
 70 |             npm = "npm install @tauri-apps/plugin-biometric"
 71 |             yarn = "yarn add @tauri-apps/plugin-biometric"
 72 |             pnpm = "pnpm add @tauri-apps/plugin-biometric"
 73 |             deno = "deno add npm:@tauri-apps/plugin-biometric"
 74 |             bun = "bun add @tauri-apps/plugin-biometric"
 75 |             />
 76 |         </Steps>
 77 |     </TabItem>
 78 | 
 79 | </Tabs>
 80 | 
 81 | ## Configuration
 82 | 
 83 | On iOS the biometric plugin requires the `NSFaceIDUsageDescription` information property list value, which should describe why your app needs to use biometric authentication.
 84 | 
 85 | In the `src-tauri/Info.ios.plist` file, add the following snippet:
 86 | 
 87 | ```xml title=src-tauri/Info.ios.plist
 88 | <?xml version="1.0" encoding="UTF-8"?>
 89 | <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
 90 | <plist version="1.0">
 91 | 	<dict>
 92 | 		<key>NSFaceIDUsageDescription</key>
 93 | 		<string>Authenticate with biometric</string>
 94 | 	</dict>
 95 | </plist>
 96 | ```
 97 | 
 98 | ## Usage
 99 | 
100 | This plugin enables you to verify the availability of Biometric Authentication on a device, prompt the user for biometric authentication, and check the result to determine if the authentication was successful or not.
101 | 
102 | ### Check Status
103 | 
104 | You can check the status of Biometric Authentication, including its availability and the types of biometric authentication methods supported.
105 | 
106 | <Tabs syncKey="lang">
107 | <TabItem label="JavaScript">
108 | 
109 | ```javascript
110 | import { checkStatus } from '@tauri-apps/plugin-biometric';
111 | 
112 | const status = await checkStatus();
113 | if (status.isAvailable) {
114 |   console.log('Yes! Biometric Authentication is available');
115 | } else {
116 |   console.log(
117 |     'No! Biometric Authentication is not available due to ' + status.error
118 |   );
119 | }
120 | ```
121 | 
122 | </TabItem>
123 | <TabItem label="Rust">
124 | 
125 | ```rust
126 | use tauri_plugin_biometric::BiometricExt;
127 | 
128 | fn check_biometric(app_handle: tauri::AppHandle) {
129 |     let status = app_handle.biometric().status().unwrap();
130 |     if status.is_available {
131 |         println!("Yes! Biometric Authentication is available");
132 |     } else {
133 |         println!("No! Biometric Authentication is not available due to: {}", status.error.unwrap());
134 |     }
135 | }
136 | ```
137 | 
138 | </TabItem>
139 | </Tabs>
140 | 
141 | ### Authenticate
142 | 
143 | To prompt the user for Biometric Authentication, utilize the `authenticate()` method.
144 | 
145 | <Tabs syncKey="lang">
146 | 
147 | <TabItem label="JavaScript">
148 | 
149 | ```javascript ins={18}
150 | import { authenticate } from '@tauri-apps/plugin-biometric';
151 | 
152 | const options = {
153 |   // Set true if you want the user to be able to authenticate using phone password
154 |   allowDeviceCredential: false,
155 |   cancelTitle: "Feature won't work if Canceled",
156 | 
157 |   // iOS only feature
158 |   fallbackTitle: 'Sorry, authentication failed',
159 | 
160 |   // Android only features
161 |   title: 'Tauri feature',
162 |   subtitle: 'Authenticate to access the locked Tauri function',
163 |   confirmationRequired: true,
164 | };
165 | 
166 | try {
167 |   await authenticate('This feature is locked', options);
168 |   console.log(
169 |     'Hooray! Successfully Authenticated! We can now perform the locked Tauri function!'
170 |   );
171 | } catch (err) {
172 |   console.log('Oh no! Authentication failed because ' + err.message);
173 | }
174 | ```
175 | 
176 | </TabItem>
177 | 
178 | <TabItem label="Rust">
179 | 
180 | ```rust ins={21}
181 | use tauri_plugin_biometric::{BiometricExt, AuthOptions};
182 | 
183 | fn bio_auth(app_handle: tauri::AppHandle) {
184 | 
185 |     let options = AuthOptions {
186 |         // Set True if you want the user to be able to authenticate using phone password
187 |         allow_device_credential:false,
188 |         cancel_title: Some("Feature won't work if Canceled".to_string()),
189 | 
190 |         // iOS only feature
191 |         fallback_title: Some("Sorry, authentication failed".to_string()),
192 | 
193 |         // Android only features
194 |         title: Some("Tauri feature".to_string()),
195 |         subtitle: Some("Authenticate to access the locked Tauri function".to_string()),
196 |         confirmation_required: Some(true),
197 |     };
198 | 
199 |     // if the authentication was successful, the function returns Result::Ok()
200 |     // otherwise returns Result::Error()
201 |     match app_handle.biometric().authenticate("This feature is locked".to_string(), options) {
202 |         Ok(_) => {
203 |             println!("Hooray! Successfully Authenticated! We can now perform the locked Tauri function!");
204 |         }
205 |         Err(e) => {
206 |             println!("Oh no! Authentication failed because : {e}");
207 |         }
208 |     }
209 | }
210 | ```
211 | 
212 | </TabItem>
213 | </Tabs>
214 | 
215 | ## Permissions
216 | 
217 | By default all potentially dangerous plugin commands and scopes are blocked and cannot be accessed. You must modify the permissions in your `capabilities` configuration to enable these.
218 | 
219 | See the [Capabilities Overview](/security/capabilities/) for more information and the [step by step guide](/learn/security/using-plugin-permissions/) to use plugin permissions.
220 | 
221 | ```json title="src-tauri/capabilities/default.json" ins={6}
222 | {
223 |   "$schema": "../gen/schemas/desktop-schema.json",
224 |   "identifier": "main-capability",
225 |   "description": "Capability for the main window",
226 |   "windows": ["main"],
227 |   "permissions": ["biometric:default"]
228 | }
229 | ```
