 90 |           "identifier": "http:default",
 91 |           "allow": [{ "url": "https://*.tauri.app" }],
 92 |           "deny": [{ "url": "https://private.tauri.app" }]
 93 |         }
 94 |       ]
 95 |     }
 96 |     ```
 97 | 
 98 |     For more information, please see the documentation for [Permissions Overview](/security/permissions/)
 99 | 
100 | 2.  Send a request
101 | 
102 |     The `fetch` method tries to be as close and compliant to the [`fetch` Web API](https://developer.mozilla.org/en-US/docs/Web/API/Fetch_API) as possible.
103 | 
104 |     ```javascript
105 |     import { fetch } from '@tauri-apps/plugin-http';
106 | 
107 |     // Send a GET request
108 |     const response = await fetch('http://test.tauri.app/data.json', {
109 |       method: 'GET',
110 |     });
111 |     console.log(response.status); // e.g. 200
112 |     console.log(response.statusText); // e.g. "OK"
113 |     ```
114 | 
115 |     :::note
116 | 
117 |     [Forbidden request headers] are ignored by default. To use them you must enable the `unsafe-headers` feature flag:
118 | 
119 |     ```toml title="src-tauri/Cargo.toml"
120 |     [dependencies]
121 |     tauri-plugin-http = { version = "2", features = ["unsafe-headers"] }
122 |     ```
123 | 
124 |     :::
125 | 
126 | </Steps>
127 | 
128 | ### Rust
129 | 
130 | In Rust you can utilize the `reqwest` crate re-exported by the plugin. For more details refer to [reqwest docs](https://docs.rs/reqwest/).
131 | 
132 | ```rust
133 | use tauri_plugin_http::reqwest;
134 | 
135 | let res = reqwest::get("http://my.api.host/data.json").await;
136 | println!("{:?}", res.status()); // e.g. 200
137 | println!("{:?}", res.text().await); // e.g Ok("{ Content }")
138 | ```
139 | 
140 | <PluginPermissions plugin={frontmatter.plugin} />
141 | 
142 | [Forbidden request headers]: https://fetch.spec.whatwg.org/#terminology-headers
