 78 | ## Usage
 79 | 
 80 | The plugin must be initialized with a password hash function, which takes the password string and must return a 32 bytes hash derived from it.
 81 | 
 82 | ### Initialize with argon2 password hash function
 83 | 
 84 | The Stronghold plugin offers a default hash function using the [argon2] algorithm.
 85 | 
 86 | ```rust title="src-tauri/src/lib.rs"
 87 | use tauri::Manager;
 88 | 
 89 | pub fn run() {
 90 |     tauri::Builder::default()
 91 |         .setup(|app| {
 92 |             let salt_path = app
 93 |                 .path()
 94 |                 .app_local_data_dir()
 95 |                 .expect("could not resolve app local data path")
 96 |                 .join("salt.txt");
 97 |             app.handle().plugin(tauri_plugin_stronghold::Builder::with_argon2(&salt_path).build())?;
 98 |             Ok(())
 99 |         })
100 |         .run(tauri::generate_context!())
101 |         .expect("error while running tauri application");
102 | }
103 | ```
104 | 
105 | ### Initialize with custom password hash function
106 | 
107 | Alternatively you can provide your own hash algorithm by using the `tauri_plugin_stronghold::Builder::new` constructor.
108 | 
109 | :::note
110 | The password hash must contain exactly 32 bytes. This is a Stronghold requirement.
111 | :::
112 | 
113 | ```rust title="src-tauri/src/lib.rs"
114 | pub fn run() {
115 |     tauri::Builder::default()
116 |         .plugin(
117 |             tauri_plugin_stronghold::Builder::new(|password| {
118 |                 // Hash the password here with e.g. argon2, blake2b or any other secure algorithm
119 |                 // Here is an example implementation using the `rust-argon2` crate for hashing the password
120 |                 use argon2::{hash_raw, Config, Variant, Version};
121 | 
122 |                 let config = Config {
123 |                     lanes: 4,
124 |                     mem_cost: 10_000,
125 |                     time_cost: 10,
126 |                     variant: Variant::Argon2id,
127 |                     version: Version::Version13,
128 |                     ..Default::default()
129 |                 };
130 |                 let salt = "your-salt".as_bytes();
131 |                 let key = hash_raw(password.as_ref(), salt, &config).expect("failed to hash password");
132 | 
133 |                 key.to_vec()
134 |             })
135 |             .build(),
136 |         )
137 |         .run(tauri::generate_context!())
138 |         .expect("error while running tauri application");
139 | }
140 | ```
141 | 
142 | ### Usage from JavaScript
143 | 
144 | The stronghold plugin is available in JavaScript.
145 | 
146 | ```javascript
147 | import { Client, Stronghold } from '@tauri-apps/plugin-stronghold';
148 | // when using `"withGlobalTauri": true`, you may use
149 | // const { Client, Stronghold } = window.__TAURI__.stronghold;
150 | import { appDataDir } from '@tauri-apps/api/path';
151 | // when using `"withGlobalTauri": true`, you may use
152 | // const { appDataDir } = window.__TAURI__.path;
153 | 
154 | const initStronghold = async () => {
155 | 	const vaultPath = `${await appDataDir()}/vault.hold`;
156 | 	const vaultPassword = 'vault password';
157 | 	const stronghold = await Stronghold.load(vaultPath, vaultPassword);
158 | 
159 | 	let client: Client;
160 | 	const clientName = 'name your client';
161 | 	try {
162 | 		client = await stronghold.loadClient(clientName);
163 | 	} catch {
164 | 		client = await stronghold.createClient(clientName);
165 | 	}
166 | 
167 | 	return {
168 | 		stronghold,
169 | 		client,
170 | 	};
171 | };
172 | 
173 | // Insert a record to the store
174 | async function insertRecord(store: any, key: string, value: string) {
175 | 	const data = Array.from(new TextEncoder().encode(value));
176 | 	await store.insert(key, data);
177 | }
178 | 
179 | // Read a record from store
180 | async function getRecord(store: any, key: string): Promise<string> {
181 | 	const data = await store.get(key);
182 | 	return new TextDecoder().decode(new Uint8Array(data));
183 | }
184 | 
185 | const { stronghold, client } = await initStronghold();
186 | 
187 | const store = client.getStore();
188 | const key = 'my_key';
189 | 
190 | // Insert a record to the store
191 | insertRecord(store, key, 'secret value');
192 | 
193 | // Read a record from store
194 | const value = await getRecord(store, key);
195 | console.log(value); // 'secret value'
196 | 
197 | // Save your updates
198 | await stronghold.save();
199 | 
200 | // Remove a record from store
201 | await store.remove(key);
202 | ```
