127 |   "$schema": "../gen/schemas/mobile-schema.json",
128 |   "identifier": "mobile-capability",
129 |   "windows": ["main"],
130 |   "platforms": ["iOS", "android"],
131 |   "permissions": ["barcode-scanner:allow-scan", "barcode-scanner:allow-cancel"]
132 | }
133 | ```
