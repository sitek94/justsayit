{
  "identifier": "desktop-capability",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "updater:default",
    "dialog:default",
    "stronghold:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "global-shortcut:default"
  ]
}